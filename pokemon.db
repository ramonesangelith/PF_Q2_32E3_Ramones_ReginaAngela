CREATE TABLE pokemon (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL,
    Height REAL,
    Weight REAL,
    Sprite TEXT,
    TrainerId INTEGER
);

